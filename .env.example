# Public URL of the deployed site (no trailing slash). Used for canonical, OG, JSON-LD.
VITE_SITE_URL=https://example.com

# Lead form: formspree | brevo | mailchimp | whatsapp | disabled
# For Formspree/Brevo/Mailchimp HTML actions, paste the form POST URL in VITE_LEAD_ENDPOINT.
VITE_LEAD_PROVIDER=disabled
VITE_LEAD_ENDPOINT=

# Optional — if you use Mailchimp embed with list id (custom handler)
VITE_MAILCHIMP_USER_ID=
VITE_MAILCHIMP_LIST_ID=

# Optional absolute image for social cards (defaults to favicon.svg on the same origin)
# VITE_OG_IMAGE_URL=
